# Server (required for AI answers) — get a key at https://console.groq.com/
GROQ_API_KEY=your_api_key_here

# Server port (optional)
PORT=5000

# Client: API base URL when the backend is not on localhost:5000 (optional)
VITE_API_URL=http://localhost:5000

# Some templates use VITE_AI_API_KEY — this project uses GROQ_API_KEY on the server only.
# VITE_AI_API_KEY=not_used_set_GROQ_API_KEY_instead
